{
  "server": {
    "name": "dev-mcp-server",
    "version": "1.0.0",
    "host": "localhost",
    "port": 8080,
    "environment": "development"
  },
  "logging": {
    "level": "DEBUG",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/dev.log",
    "console": true
  },
  "tools": {
    "enabled": ["calculator", "web_search", "database_query"],
    "timeout": 30,
    "max_concurrent": 5
  },
  "security": {
    "sandbox_enabled": true,
    "validate_inputs": true,
    "allowed_hosts": ["localhost", "127.0.0.1"],
    "max_request_size": 1048576
  },
  "resources": {
    "max_memory_mb": 512,
    "max_cpu_percent": 50,
    "max_execution_time": 60
  },
  "database": {
    "type": "sqlite",
    "path": "data/dev.db",
    "pool_size": 5
  },
  "cache": {
    "enabled": true,
    "ttl": 1800,
    "max_size": 50
  },
  "features": {
    "auto_register_tools": true,
    "enable_metrics": true,
    "enable_health_check": true
  }
}
