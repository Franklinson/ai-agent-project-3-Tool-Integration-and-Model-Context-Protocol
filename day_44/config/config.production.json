{
  "server": {
    "name": "prod-mcp-server",
    "version": "1.0.0",
    "host": "0.0.0.0",
    "port": 8080,
    "environment": "production"
  },
  "logging": {
    "level": "WARNING",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s - %(funcName)s:%(lineno)d",
    "file": "logs/production.log",
    "console": false,
    "json_format": true,
    "rotation": {
      "max_bytes": 10485760,
      "backup_count": 10
    }
  },
  "tools": {
    "enabled": ["calculator", "web_search", "database_query", "api_tool"],
    "timeout": 60,
    "max_concurrent": 20,
    "retry_attempts": 3,
    "retry_delay": 2
  },
  "security": {
    "sandbox_enabled": true,
    "validate_inputs": true,
    "allowed_hosts": ["*"],
    "max_request_size": 5242880,
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 100,
      "burst": 20
    },
    "cors": {
      "enabled": true,
      "allowed_origins": ["https://example.com"],
      "allowed_methods": ["GET", "POST"]
    }
  },
  "resources": {
    "max_memory_mb": 1024,
    "max_cpu_percent": 80,
    "max_execution_time": 120,
    "worker_threads": 4
  },
  "database": {
    "type": "postgresql",
    "host": "${DB_HOST}",
    "port": 5432,
    "database": "${DB_NAME}",
    "username": "${DB_USER}",
    "password": "${DB_PASSWORD}",
    "pool_size": 20,
    "max_overflow": 10,
    "ssl_mode": "require"
  },
  "cache": {
    "enabled": true,
    "type": "redis",
    "host": "${REDIS_HOST}",
    "port": 6379,
    "password": "${REDIS_PASSWORD}",
    "ttl": 3600,
    "max_size": 1000
  },
  "monitoring": {
    "enabled": true,
    "metrics_port": 9090,
    "health_check_path": "/health",
    "readiness_check_path": "/ready",
    "prometheus_enabled": true
  },
  "scaling": {
    "auto_scale": true,
    "min_instances": 2,
    "max_instances": 10,
    "target_cpu_utilization": 70
  },
  "features": {
    "auto_register_tools": false,
    "enable_metrics": true,
    "enable_health_check": true,
    "enable_tracing": true,
    "graceful_shutdown": true,
    "shutdown_timeout": 30
  },
  "alerts": {
    "enabled": true,
    "email": "${ALERT_EMAIL}",
    "slack_webhook": "${SLACK_WEBHOOK}",
    "thresholds": {
      "error_rate": 5,
      "response_time_ms": 1000,
      "cpu_percent": 85
    }
  }
}
